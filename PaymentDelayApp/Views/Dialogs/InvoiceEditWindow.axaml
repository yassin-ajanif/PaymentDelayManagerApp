<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        xmlns:m="using:PaymentDelayApp.BusinessLayer.Models"
        x:Class="PaymentDelayApp.Views.Dialogs.InvoiceEditWindow"
        x:DataType="vm:InvoiceEditViewModel"
        Width="640"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}">
    <DockPanel Margin="28,24">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,0,0,20">
            <Button Content="Enregistrer" Padding="14,6" Command="{Binding SaveCommand}" />
            <Button Content="Annuler" Padding="14,6" Command="{Binding CancelCommand}" />
        </StackPanel>
        <ScrollViewer Padding="0,0,8,0">
            <StackPanel Spacing="4">
                <Grid ColumnDefinitions="220,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="18"
                      ColumnSpacing="24">
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Classes="dialog-label"
                               Text="Date de facture"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0" />
                    <DatePicker Grid.Row="0" Grid.Column="1"
                                SelectedDate="{Binding InvoiceDateUi}"
                                MinYear="{Binding InvoiceDatePickerMinYear}"
                                MaxYear="{Binding InvoiceDatePickerMaxYear}"
                                MinHeight="36" />
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Classes="dialog-label"
                               Text="Date de livraison ou préstation"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0" />
                    <DatePicker Grid.Row="1" Grid.Column="1"
                                SelectedDate="{Binding DeliveryDateUi}"
                                MinYear="{Binding InvoiceDatePickerMinYear}"
                                MaxYear="{Binding InvoiceDatePickerMaxYear}"
                                MinHeight="36" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="dialog-label" Text="N° de Facture" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InvoiceNumber}" MinHeight="36" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="dialog-label" Text="Fournisseur" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0" />
                    <ComboBox Grid.Row="3" Grid.Column="1"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              MinHeight="36">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="m:Supplier">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="dialog-label" Text="Désignation" VerticalAlignment="Top" TextWrapping="Wrap" Margin="0,6,8,0" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Designation}" AcceptsReturn="True" MinHeight="56" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="dialog-label" Text="TTC" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0" />
                    <NumericUpDown Grid.Row="5" Grid.Column="1"
                                   Minimum="0"
                                   Maximum="1000000000"
                                   Increment="0.01"
                                   Value="{Binding TtcAmount}"
                                   FormatString="N2"
                                   MinHeight="36" />
                    <TextBlock Grid.Row="6" Grid.Column="0"
                               Classes="dialog-label"
                               Text="Date d'échéance/facture"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0" />
                    <NumericUpDown Grid.Row="6" Grid.Column="1"
                                   Maximum="120"
                                   Value="{Binding EcheanceFactureJours}"
                                   FormatString="N0"
                                   MinHeight="36" />
                    <TextBlock Grid.Row="7" Grid.Column="0"
                               Classes="dialog-label"
                               Text="Date d'échéance normale"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Row="7" Grid.Column="1"
                               Classes="dialog-label"
                               Text="{Binding EcheanceNormaleDisplay}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <TextBlock Grid.Row="8" Grid.Column="0"
                               Classes="dialog-label"
                               Text="Date d'échéance respectée"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Row="8" Grid.Column="1"
                               Classes="dialog-label"
                               Text="{Binding EcheanceRespecteeDisplay}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <TextBlock Grid.Row="9" Grid.Column="0" Classes="dialog-label" Text="Reste des jours" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="9" Grid.Column="1"
                               Classes="dialog-label"
                               Text="{Binding ResteDisplay}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
