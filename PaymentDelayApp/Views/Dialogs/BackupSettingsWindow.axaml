<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.BackupSettingsWindow"
        x:DataType="vm:BackupSettingsViewModel"
        Width="640"
        MinWidth="640"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Sauvegardes">
    <Window.Styles>
        <Style Selector="Button.outlinebutton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBluePrimary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushBluePrimary}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.outlinebutton:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushSurface}" />
        </Style>
        <Style Selector="Button.outlinebutton:pressed">
            <Setter Property="Background" Value="{DynamicResource AppBrushBorder}" />
        </Style>
    </Window.Styles>
    <Border Padding="20" Margin="0">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="20">
            <TextBlock Grid.Row="0"
                       Text="SAUVEGARDES"
                       FontSize="11"
                       FontWeight="SemiBold"
                       LetterSpacing="1.2"
                       Foreground="{DynamicResource AppBrushTextSecondary}" />
            <Grid Grid.Row="1"
                  ColumnDefinitions="160,*,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="14">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Chemin de la base"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppBrushTextPrimary}" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding DatabasePath}"
                         FontFamily="Consolas,Courier New,monospace"
                         MinHeight="36"
                         VerticalContentAlignment="Center"
                         Watermark="C:\…\app.db" />
                <Button Grid.Row="0" Grid.Column="2"
                        Classes="outlinebutton"
                        Content="Parcourir…"
                        MinWidth="108"
                        MinHeight="36"
                        Padding="10,6"
                        VerticalAlignment="Center"
                        Command="{Binding BrowseDatabasePathCommand}"
                        ToolTip.Tip="Choisir le fichier de base SQLite" />
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Dossier de sauvegarde"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppBrushTextPrimary}" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding BackupsDirectory}"
                         FontFamily="Consolas,Courier New,monospace"
                         MinHeight="36"
                         VerticalContentAlignment="Center"
                         Watermark="C:\…\backups" />
                <Button Grid.Row="1" Grid.Column="2"
                        Classes="outlinebutton"
                        Content="Parcourir…"
                        MinWidth="108"
                        MinHeight="36"
                        Padding="10,6"
                        VerticalAlignment="Center"
                        Command="{Binding BrowseBackupsDirectoryCommand}"
                        ToolTip.Tip="Choisir le dossier des sauvegardes" />
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Rétention (jours)"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppBrushTextPrimary}" />
                <NumericUpDown Grid.Row="2" Grid.Column="1"
                               Minimum="1"
                               Maximum="365"
                               Value="{Binding RetentionDays}"
                               Width="120"
                               HorizontalAlignment="Left"
                               Increment="1"
                               FormatString="0"
                               ShowButtonSpinner="True" />
            </Grid>
            <Button Grid.Row="2"
                    Classes="outlinebutton"
                    Content="Enregistrer"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    Command="{Binding SaveCommand}" />
        </Grid>
    </Border>
</Window>
