<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.SupplierFormWindow"
        x:DataType="vm:SupplierFormViewModel"
        Width="520"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,0,0,16">
            <Button Classes="bluebutton" Content="Enregistrer" Padding="14,6" Command="{Binding SaveCommand}" />
            <Button Classes="bluebutton" Content="Annuler" Padding="14,6" Command="{Binding CancelCommand}" />
        </StackPanel>
        <ScrollViewer>
            <StackPanel Spacing="14">
                <TextBlock Classes="dialog-section-title" Text="Fournisseur" />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="dialog-label" Text="Nom *" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Watermark="Raison sociale" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="dialog-label" Text="ICE" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Ice}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="dialog-label" Text="IF" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FiscalId}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="dialog-label" Text="Adresse" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Address}" AcceptsReturn="True" MinHeight="56" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="dialog-label" Text="Activité" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Activite}" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="dialog-label" Text="Seuil d'alerte (jours)" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="5" Grid.Column="1"
                                   Minimum="0"
                                   Maximum="365"
                                   Value="{Binding AlertSeuilJours}"
                                   FormatString="N0" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
