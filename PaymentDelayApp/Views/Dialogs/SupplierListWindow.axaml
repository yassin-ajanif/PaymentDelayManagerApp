<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.SupplierListWindow"
        x:DataType="vm:SupplierListViewModel"
        Width="920"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Title="Liste des fournisseurs">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="Actualiser" Command="{Binding RefreshCommand}" Padding="12,6" />
            <Button Content="Fermer" Command="{Binding CloseCommand}" Padding="12,6" />
        </StackPanel>
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <TextBlock Grid.Row="0" Classes="dialog-section-title" Text="Liste fournisseur" FontSize="15" />
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SupplierRows}"
                      SelectedItem="{Binding SelectedSupplierRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      PointerReleased="SupplierGrid_OnPointerReleased"
                      DoubleTapped="SupplierGrid_OnDoubleTapped">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*" MinWidth="140" />
                    <DataGridTextColumn Header="ICE" Binding="{Binding Ice}" Width="120" />
                    <DataGridTextColumn Header="IF" Binding="{Binding FiscalId}" Width="100" />
                    <DataGridTextColumn Header="Adresse" Binding="{Binding Address}" Width="1.5*" MinWidth="120" />
                    <DataGridTextColumn Header="Activite" Binding="{Binding Activite}" Width="*" MinWidth="100" />
                    <DataGridTextColumn Header="Seuil alerte (j)" Binding="{Binding AlertSeuilJours}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
