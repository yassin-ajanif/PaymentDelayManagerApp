<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.MessageWindow"
        x:DataType="vm:MessageDialogViewModel"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
    <Border Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
            <Button Content="OK" MinWidth="100" HorizontalAlignment="Right" Command="{Binding OkCommand}" />
        </StackPanel>
    </Border>
</Window>
