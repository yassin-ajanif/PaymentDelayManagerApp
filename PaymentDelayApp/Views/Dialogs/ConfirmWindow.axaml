<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.ConfirmWindow"
        x:DataType="vm:ConfirmDialogViewModel"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
    <Border Padding="20" Margin="0">
        <StackPanel Spacing="16">
            <TextBlock Classes="dialog-body" Text="{Binding Message}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Non" MinWidth="88" Command="{Binding NoCommand}" />
                <Button Content="Oui" MinWidth="88" Command="{Binding YesCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
