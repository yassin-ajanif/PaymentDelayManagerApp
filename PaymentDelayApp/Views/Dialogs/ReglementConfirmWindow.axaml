<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.ReglementConfirmWindow"
        x:DataType="vm:ReglementDialogViewModel"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Confirmer le règlement">
    <Border Padding="20">
        <StackPanel Spacing="14">
            <TextBlock TextWrapping="Wrap"
                       Text="Entrez la date et l'heure auxquelles vous enregistrez le paiement (par défaut : maintenant)." />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Date du règlement" VerticalAlignment="Center" />
                <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding SelectedDate}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Heure" VerticalAlignment="Center" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <NumericUpDown Minimum="0" Maximum="23" Value="{Binding Hour}" Width="80" FormatString="N0" />
                    <TextBlock Text="h" VerticalAlignment="Center" />
                    <NumericUpDown Minimum="0" Maximum="59" Value="{Binding Minute}" Width="80" FormatString="N0" />
                    <TextBlock Text="min" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Annuler" MinWidth="100" Command="{Binding CancelCommand}" />
                <Button Content="Confirmer le règlement" MinWidth="160" Command="{Binding ConfirmCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
