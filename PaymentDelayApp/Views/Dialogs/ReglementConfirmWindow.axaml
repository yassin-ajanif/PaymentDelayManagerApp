<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        x:Class="PaymentDelayApp.Views.Dialogs.ReglementConfirmWindow"
        x:DataType="vm:ReglementDialogViewModel"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Confirmer le règlement">
    <Border Padding="20">
        <StackPanel Spacing="14">
            <TextBlock Classes="dialog-body"
                       TextWrapping="Wrap"
                       Text="Indiquez la date à laquelle vous enregistrez le paiement (par défaut : aujourd'hui)." />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" RowSpacing="10" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="dialog-label" Text="Date du règlement" VerticalAlignment="Center" />
                <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding SelectedDate}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Classes="bluebutton" Content="Annuler" MinWidth="100" Command="{Binding CancelCommand}" />
                <Button Classes="bluebutton" Content="Confirmer le règlement" MinWidth="160" Command="{Binding ConfirmCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
