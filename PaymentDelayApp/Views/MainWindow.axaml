<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        xmlns:models="using:PaymentDelayApp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        MinWidth="960"
        MinHeight="560"
        x:Class="PaymentDelayApp.Views.MainWindow"
        x:DataType="vm:DashboardViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Retard de paiement">

    <Design.DataContext>
        <vm:DashboardViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextPrimary}" />
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextSecondary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushFieldBorder}" />
            <Setter Property="Background" Value="{DynamicResource AppBrushCard}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextPrimary}" />
            <Setter Property="FontSize" Value="{DynamicResource AppFontSizeUi}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushSurface}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushBluePrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBluePrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushBlueButtonHover}" />
        </Style>
        <!-- Same base as filter-chip; green when checked (needs .filter-chip for global Button exclusion) -->
        <Style Selector="ToggleButton.filter-chip.filter-chip-settled:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushGreenPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushGreenPrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-settled:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushGreenButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-unsettled:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushAmberPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushAmberPrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-unsettled:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushAmberButtonHover}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="16" RowSpacing="12">

        <!-- Titre + actions -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Spacing="8">
                <TextBlock Classes="title" Text="Dashboard" FontSize="22" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Classes="subtitle"
                               Text="Factures — recherche et liste"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleButton Classes="filter-chip"
                                      Content="{Binding AlertFilterChipCaption}"
                                      IsChecked="{Binding ShowAlertInvoicesOnly, Mode=TwoWay}" />
                        <ToggleButton Classes="filter-chip filter-chip-unsettled"
                                      Content="{Binding UnsettledFilterChipCaption}"
                                      IsChecked="{Binding ShowUnsettledInvoicesOnly, Mode=TwoWay}" />
                        <ToggleButton Classes="filter-chip filter-chip-settled"
                                      Content="{Binding SettledFilterChipCaption}"
                                      IsChecked="{Binding ShowSettledInvoicesOnly, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Paramètres" Padding="12,6" IsEnabled="False" Opacity="0.5" />
                <Button Content="Actualiser" Padding="12,6" Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <!-- Barre recherche + liens plan -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppBrushCard}"
                BorderBrush="{DynamicResource AppBrushBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <TextBlock Text="Recherche facture" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBox Grid.Column="1"
                         Watermark="N° facture, fournisseur, désignation…"
                         Text="{Binding SearchText}"
                         MinHeight="36" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="Ajouter fournisseur" Command="{Binding AddSupplierCommand}" Padding="10,6" />
                    <Button Content="Nouvelle facture" Command="{Binding NewInvoiceCommand}" Padding="10,6" />
                    <Button Content="Liste fournisseurs" Command="{Binding OpenSupplierListCommand}" Padding="10,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource AppBrushFieldBorder}"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True">
            <DataGrid x:Name="InvoiceGrid"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      PointerReleased="InvoiceGrid_OnPointerReleased"
                      DoubleTapped="InvoiceGrid_OnDoubleTapped">
                <DataGrid.RowTheme>
                    <ControlTheme x:DataType="models:InvoiceDashboardRow"
                                  TargetType="DataGridRow"
                                  BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="Background" Value="{Binding RowStripeBackground}" />
                    </ControlTheme>
                </DataGrid.RowTheme>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date de facture" Binding="{Binding DateFactureDisplay}" Width="120" />
                <DataGridTextColumn Header="Date de livraison ou préstation" Binding="{Binding DateLivraisonDisplay}" Width="160" />
                <DataGridTextColumn Header="N° de Facture" Binding="{Binding InvoiceNumber}" Width="110" />
                <DataGridTextColumn Header="Fournisseur" Binding="{Binding SupplierName}" Width="200" MinWidth="120" />
                <DataGridTextColumn Header="Désignation" Binding="{Binding Designation}" Width="200" MinWidth="140" />
                <DataGridTextColumn Header="TTC" Binding="{Binding TtcDisplay}" Width="90" />
                <DataGridTextColumn Header="Date d'échéance normale" Binding="{Binding EcheanceNormaleDisplay}" Width="130" />
                <DataGridTextColumn Header="Date d'échéance respectée" Binding="{Binding EcheanceRespecteeDisplay}" Width="150" />
                <DataGridTemplateColumn Header="Reste des jours"
                                        Width="110"
                                        SortMemberPath="ResteDesJours">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="models:InvoiceDashboardRow">
                            <Panel VerticalAlignment="Center" Margin="8,4">
                                <TextBlock Text="{Binding ResteDisplay}"
                                           Foreground="{DynamicResource AppBrushResteAlert}"
                                           IsVisible="{Binding IsResteJoursAlert}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ResteDisplay}"
                                           Foreground="{DynamicResource AppBrushTextPrimary}"
                                           IsVisible="{Binding IsResteJoursNormalColor}"
                                           VerticalAlignment="Center" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Date d'échéance/facture" Binding="{Binding EcheanceFactureDisplay}" Width="140" />
            </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
