<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PaymentDelayApp.ViewModels"
        xmlns:models="using:PaymentDelayApp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        MinWidth="960"
        MinHeight="560"
        x:Class="PaymentDelayApp.Views.MainWindow"
        x:DataType="vm:DashboardViewModel"
        Icon="/Assets/AppIcon.png"
        Title="Délais de paiement">

    <Design.DataContext>
        <vm:DashboardViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextPrimary}" />
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextSecondary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushFieldBorder}" />
            <Setter Property="Background" Value="{DynamicResource AppBrushCard}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushTextPrimary}" />
            <Setter Property="FontSize" Value="{DynamicResource AppFontSizeUi}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushSurface}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushBluePrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBluePrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushBlueButtonHover}" />
        </Style>
        <!-- Same base as filter-chip; green when checked -->
        <Style Selector="ToggleButton.filter-chip.filter-chip-settled:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushGreenPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushGreenPrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-settled:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushGreenButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-unsettled:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushAmberPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource AppBrushWhite}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushAmberPrimary}" />
        </Style>
        <Style Selector="ToggleButton.filter-chip.filter-chip-unsettled:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushAmberButtonHover}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="16" RowSpacing="12">

        <!-- Titre + actions -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Spacing="8">
                <TextBlock Classes="title" Text="Dashboard" FontSize="22" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Classes="subtitle"
                               Text="Factures — recherche et liste"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleButton Classes="filter-chip"
                                      Content="{Binding AlertFilterChipCaption}"
                                      IsChecked="{Binding ShowAlertInvoicesOnly, Mode=TwoWay}" />
                        <ToggleButton Classes="filter-chip filter-chip-unsettled"
                                      Content="{Binding UnsettledFilterChipCaption}"
                                      IsChecked="{Binding ShowUnsettledInvoicesOnly, Mode=TwoWay}" />
                        <ToggleButton Classes="filter-chip filter-chip-settled"
                                      Content="{Binding SettledFilterChipCaption}"
                                      IsChecked="{Binding ShowSettledInvoicesOnly, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Classes="exportfiletile"
                        ToolTip.Tip="Importer un fichier Excel (même format que l'export)"
                        Command="{Binding ImportExcelCommand}"
                        VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="2" ClipToBounds="True">
                        <Grid>
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="0"
                                        Background="{DynamicResource AppBrushExportExcelGreenLight}" />
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AppBrushExportExcelGreenDark}" />
                            </Grid>
                            <TextBlock Text="↓"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppBrushWhite}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>
                <Button Classes="bluebutton"
                        Content="Paramètres"
                        Padding="12,6">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem Header="Intervalle de surveillance"
                                      Command="{Binding OpenWatcherSettingsCommand}" />
                            <MenuItem Header="Sauvegardes"
                                      Command="{Binding OpenBackupSettingsCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Classes="bluebutton" Content="Actualiser" Padding="12,6" Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <!-- Barre recherche + liens plan -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppBrushCard}"
                BorderBrush="{DynamicResource AppBrushBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="12">
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <TextBlock Text="Recherche facture" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Watermark="N° facture, fournisseur, désignation…"
                             Text="{Binding SearchText}"
                             MinHeight="36" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Classes="bluebutton" Content="Ajouter fournisseur" Command="{Binding AddSupplierCommand}" Padding="10,6" />
                        <Button Classes="bluebutton" Content="Nouvelle facture" Command="{Binding NewInvoiceCommand}" Padding="10,6" />
                        <Button Classes="bluebutton" Content="Liste fournisseurs" Command="{Binding OpenSupplierListCommand}" Padding="10,6" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                      ColumnSpacing="8">
                    <TextBlock Text="Date de facture"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,4,0" />
                    <TextBlock Grid.Column="1"
                               Text="Du"
                               VerticalAlignment="Center"
                               Margin="0,0,2,0" />


                    <DatePicker Grid.Column="2"
                                SelectedDate="{Binding InvoiceDateFilterFrom}"
                                MinYear="{Binding InvoiceDateFilterPickerMin}"
                                MaxYear="{Binding InvoiceDateFilterPickerMax}"
                                MinHeight="36"
                                Width="150"
                                 />

                                

                    <TextBlock Grid.Column="3"
                               Text="Au"
                               VerticalAlignment="Center"
                               Margin="4,0,2,0" />
                    
                    <DatePicker Grid.Column="4"
                                SelectedDate="{Binding InvoiceDateFilterTo}"
                                MinYear="{Binding InvoiceDateFilterPickerMin}"
                                MaxYear="{Binding InvoiceDateFilterPickerMax}"
                                MinHeight="36"
                                Width="150"
                                />


                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Classes="exportfiletile"
                                ToolTip.Tip="Exporter en PDF"
                                Command="{Binding ExportPdfCommand}">
                            <Border Width="20" Height="20" CornerRadius="2" ClipToBounds="True">
                                <Grid RowDefinitions="10,*">
                                    <Border Grid.Row="0" Background="{DynamicResource AppBrushExportPdfDoc}">
                                        <Grid>
                                            <Path Fill="#C5C5C5"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top"
                                                  Data="M14,0 L20,0 L20,5 L14,5 Z" />
                                            <Path Fill="#B0B0B0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top"
                                                  Data="M16,0 L20,0 L20,5 Z" />
                                            <Path Stroke="#A0A0A0"
                                                  StrokeThickness="0.55"
                                                  Margin="2,2,2,0"
                                                  VerticalAlignment="Top"
                                                  Data="M2,2 H12 M2,4 H10" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource AppBrushExportPdfRed}">
                                        <TextBlock Text="PDF"
                                                   Foreground="{DynamicResource AppBrushWhite}"
                                                   FontSize="5.5"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>
                        <Button Classes="exportfiletile"
                                ToolTip.Tip="Exporter en Excel"
                                Command="{Binding ExportExcelCommand}">
                            <Border Width="20" Height="20" CornerRadius="2" ClipToBounds="True">
                                <Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource AppBrushExportExcelGreenLight}" />
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource AppBrushExportExcelGreenDark}" />
                                    </Grid>
                                    <Border Width="10" Height="10"
                                            CornerRadius="1.5"
                                            Background="{DynamicResource AppBrushExportExcelGreen}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="2,0,0,0">
                                        <TextBlock Text="X"
                                                   Foreground="{DynamicResource AppBrushWhite}"
                                                   FontSize="7"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>
                        <Button Classes="toolbarghosticon"
                                ToolTip.Tip="Réinitialiser les dates"
                                Command="{Binding ClearInvoiceDateFiltersCommand}">
                            <TextBlock Text="&#x21ba;"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBrushTextSecondary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource AppBrushFieldBorder}"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True">
            <DataGrid x:Name="InvoiceGrid"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      PointerReleased="InvoiceGrid_OnPointerReleased"
                      DoubleTapped="InvoiceGrid_OnDoubleTapped">
                <DataGrid.RowTheme>
                    <ControlTheme x:DataType="models:InvoiceDashboardRow"
                                  TargetType="DataGridRow"
                                  BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="Background" Value="{Binding RowStripeBackground}" />
                    </ControlTheme>
                </DataGrid.RowTheme>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date de facture" Binding="{Binding DateFactureDisplay}" Width="108" MinWidth="100" />
                <DataGridTextColumn Header="Date de livraison ou préstation" Binding="{Binding DateLivraisonDisplay}" Width="132" MinWidth="120" />
                <DataGridTextColumn Header="N° de Facture" Binding="{Binding InvoiceNumber}" Width="110" />
                <!-- * / 2* share extra grid width (Désignation gets more room for long text). -->
                <DataGridTextColumn Header="Fournisseur" Binding="{Binding SupplierName}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="Désignation" Binding="{Binding Designation}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="TTC" Binding="{Binding TtcDisplay}" Width="90" />
                <DataGridTextColumn Header="Date d'échéance respectée"
                                    Binding="{Binding EcheanceRespecteeDisplay}"
                                    Width="142"
                                    MinWidth="130" />
                <DataGridTemplateColumn Header="Reste des jours"
                                        Width="72"
                                        MinWidth="40"
                                        SortMemberPath="ResteDesJours">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="models:InvoiceDashboardRow">
                            <Panel VerticalAlignment="Center" Margin="4,4">
                                <TextBlock Text="{Binding ResteDisplay}"
                                           Foreground="{DynamicResource AppBrushResteAlert}"
                                           IsVisible="{Binding IsResteJoursAlert}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ResteDisplay}"
                                           Foreground="{DynamicResource AppBrushTextPrimary}"
                                           IsVisible="{Binding IsResteJoursNormalColor}"
                                           VerticalAlignment="Center" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Date d'échéance/facture"
                                    Binding="{Binding EcheanceFactureDisplay}"
                                    Width="124"
                                    MinWidth="112" />
            </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
